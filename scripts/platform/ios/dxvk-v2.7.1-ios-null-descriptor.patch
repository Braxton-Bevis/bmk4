+  void DxvkUnboundResources::clearResources() {
+    if (m_device->features().extRobustness2.nullDescriptor)
+      return;
+
+    Rc<DxvkContext> context = m_device->createContext();
+    context->beginRecording(m_device->createCommandList());
+
+    context->initImage(m_image1D, VK_IMAGE_LAYOUT_UNDEFINED);
+    context->initImage(m_image2D, VK_IMAGE_LAYOUT_UNDEFINED);
+    context->initImage(m_image3D, VK_IMAGE_LAYOUT_UNDEFINED);
+
+    m_device->submitCommandList(
+      context->endRecording(nullptr), nullptr, 0u, nullptr);
+  }
