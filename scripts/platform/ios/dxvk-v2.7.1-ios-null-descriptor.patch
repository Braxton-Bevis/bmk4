+  Rc<DxvkBufferView> DxvkUnboundResources::createBufferView(
+    const Rc<DxvkBuffer>&       buffer,
+          VkBufferUsageFlagBits usage) {
+    DxvkBufferViewKey info;
+    info.format = VK_FORMAT_R32_UINT;
+    info.usage = usage;
+    info.offset = 0u;
+    info.size = buffer->info().size;
+
+    return buffer->createView(info);
+  }
+
+
+  Rc<DxvkImage> DxvkUnboundResources::createImage(
+          VkImageType           type,
+          uint32_t              layers) {
+    const std::array<VkFormat, 2u> viewFormats = {
+      VK_FORMAT_R32_SFLOAT,
+      VK_FORMAT_R32_UINT,
+    };
+
+    DxvkImageCreateInfo info;
+    info.type = type;
+    info.format = VK_FORMAT_R32_UINT;
+    info.flags = VK_IMAGE_CREATE_MUTABLE_FORMAT_BIT;
+    info.sampleCount = VK_SAMPLE_COUNT_1_BIT;
+    info.extent = { 1u, 1u, 1u };
+    info.numLayers = layers;
+    info.mipLevels = 1u;
+    info.usage = VK_IMAGE_USAGE_TRANSFER_DST_BIT
+               | VK_IMAGE_USAGE_SAMPLED_BIT
+               | VK_IMAGE_USAGE_STORAGE_BIT;
+    info.stages = VK_PIPELINE_STAGE_TRANSFER_BIT
+                | m_device->getShaderPipelineStages();
+    info.access = VK_ACCESS_TRANSFER_WRITE_BIT
+                | VK_ACCESS_SHADER_READ_BIT
+                | VK_ACCESS_SHADER_WRITE_BIT;
+    info.layout = VK_IMAGE_LAYOUT_GENERAL;
+    info.tiling = VK_IMAGE_TILING_OPTIMAL;
+    info.viewFormatCount = viewFormats.size();
+    info.viewFormats = viewFormats.data();
+    info.debugName = "Null image";
+
+    if (type == VK_IMAGE_TYPE_2D)
+      info.flags |= VK_IMAGE_CREATE_CUBE_COMPATIBLE_BIT;
+
+    return m_device->createImage(info, VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT);
+  }
+
+
+  Rc<DxvkImageView> DxvkUnboundResources::createImageView(
+    const Rc<DxvkImage>&        image,
+          VkFormat             format,
+          VkImageViewType      type,
+          VkImageUsageFlagBits usage,
+          uint32_t             layers) {
+    DxvkImageViewKey info;
+    info.viewType = type;
+    info.usage = usage;
+    info.format = format;
+    info.layout = VK_IMAGE_LAYOUT_GENERAL;
+    info.aspects = VK_IMAGE_ASPECT_COLOR_BIT;
+    info.mipIndex = 0u;
+    info.mipCount = 1u;
+    info.layerIndex = 0u;
+    info.layerCount = layers;
+
+    if (usage == VK_IMAGE_USAGE_SAMPLED_BIT) {
+      info.packedSwizzle = DxvkImageViewKey::packSwizzle(VkComponentMapping {
+        VK_COMPONENT_SWIZZLE_ZERO, VK_COMPONENT_SWIZZLE_ZERO,
+        VK_COMPONENT_SWIZZLE_ZERO, VK_COMPONENT_SWIZZLE_ZERO });
+    }
+
+    return image->createView(info);
+  }
+
+
+  DxvkUnboundResources::UnboundViews DxvkUnboundResources::createImageViews(
+          VkFormat             format,
+          VkImageUsageFlagBits usage) {
+    UnboundViews result;
+    result.view1D = createImageView(m_image1D, format,
+      VK_IMAGE_VIEW_TYPE_1D, usage, 1u);
+    result.view1DArray = createImageView(m_image1D, format,
+      VK_IMAGE_VIEW_TYPE_1D_ARRAY, usage, 1u);
+    result.view2D = createImageView(m_image2D, format,
+      VK_IMAGE_VIEW_TYPE_2D, usage, 1u);
+    result.view2DArray = createImageView(m_image2D, format,
+      VK_IMAGE_VIEW_TYPE_2D_ARRAY, usage, 1u);
+    result.viewCube = createImageView(m_image2D, format,
+      VK_IMAGE_VIEW_TYPE_CUBE, usage, 6u);
+    result.viewCubeArray = createImageView(m_image2D, format,
+      VK_IMAGE_VIEW_TYPE_CUBE_ARRAY, usage, 6u);
+    result.view3D = createImageView(m_image3D, format,
+      VK_IMAGE_VIEW_TYPE_3D, usage, 1u);
+    return result;
+  }
+
+
+  DxvkImageView* DxvkUnboundResources::getImageView(
+          VkImageViewType       type,
+          bool                  storage) const {
+    const UnboundViews& views = storage
+      ? m_storageImageViews
+      : m_sampledImageViews;
+
+    switch (type) {
+      case VK_IMAGE_VIEW_TYPE_1D:         return views.view1D.ptr();
+      case VK_IMAGE_VIEW_TYPE_1D_ARRAY:   return views.view1DArray.ptr();
+      case VK_IMAGE_VIEW_TYPE_MAX_ENUM:
+      case VK_IMAGE_VIEW_TYPE_2D:         return views.view2D.ptr();
+      case VK_IMAGE_VIEW_TYPE_2D_ARRAY:   return views.view2DArray.ptr();
+      case VK_IMAGE_VIEW_TYPE_CUBE:       return views.viewCube.ptr();
+      case VK_IMAGE_VIEW_TYPE_CUBE_ARRAY: return views.viewCubeArray.ptr();
+      case VK_IMAGE_VIEW_TYPE_3D:         return views.view3D.ptr();
+      default:                            return nullptr;
+    }
+  }
   
 }
