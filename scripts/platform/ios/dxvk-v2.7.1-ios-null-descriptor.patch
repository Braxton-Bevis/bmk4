+
+      m_image1D = createImage(VK_IMAGE_TYPE_1D, 1u);
+      m_image2D = createImage(VK_IMAGE_TYPE_2D, 6u);
+      m_image3D = createImage(VK_IMAGE_TYPE_3D, 1u);
+
+      m_sampledImageViews = createImageViews(
+        VK_FORMAT_R32_SFLOAT, VK_IMAGE_USAGE_SAMPLED_BIT);
