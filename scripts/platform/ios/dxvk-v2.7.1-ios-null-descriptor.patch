+    if (!m_device->features().extRobustness2.nullDescriptor) {
+      m_buffer = createBuffer();
+      m_bufferCreated.store(true, std::memory_order_release);
 
+      m_sampler = createSampler();
+      m_samplerCreated.store(true, std::memory_order_release);
+
+      m_uniformTexelBufferView = createBufferView(
+        m_buffer, VK_BUFFER_USAGE_UNIFORM_TEXEL_BUFFER_BIT);
+      m_storageTexelBufferView = createBufferView(
